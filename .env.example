# Copie este arquivo para .env e preencha os valores antes de rodar o servidor.

# Senha de acesso ao painel de administração
ADMIN_PASSWORD=troque_aqui

# Chave secreta para sessões Flask — gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque_aqui

# (opcional) Porta do servidor em desenvolvimento — padrão: 5001
# PORT=5001
